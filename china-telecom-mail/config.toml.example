# China Telecom Mail Skill Configuration
# Copy this file to config.toml and fill in your credentials

[email]
# POP3 server settings
server = "pop.chinatelecom.cn"
port = 995

# Account credentials
username = "your_email@chinatelecom.cn"
password = "your_password_or授权码"

# Environment variable overrides (recommended for security):
# export CHINA_TELCOM_MAIL_USER="your_email@chinatelecom.cn"
# export CHINA_TELCOM_MAIL_PASS="your_password"
